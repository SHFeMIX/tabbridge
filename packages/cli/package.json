{
  "name": "tabbridge",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "bin": {
    "tabbridge": "dist/main.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "directory": "dist"
  },
  "scripts": {
    "build": "pnpm --filter @tabbridge/shared build && pnpm --filter @tabbridge/broker build && tsup && node scripts/post-build.cjs",
    "test": "pnpm build && vitest --run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "clean": "node scripts/clean.cjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "env-paths": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tabbridge/broker": "workspace:*",
    "@tabbridge/shared": "workspace:*",
    "@types/node": "catalog:",
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.5.13",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
