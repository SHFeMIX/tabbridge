{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["wxt", "chrome", "vitest/globals"],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": false,
    "declarationMap": false,
    "allowImportingTsExtensions": true,
    "isolatedModules": true
  },
  "include": ["src", "test", "wxt.config.ts", ".wxt/types/**/*.d.ts"]
}
